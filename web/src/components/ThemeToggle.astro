---
---

<button
  id="theme-toggle"
  aria-label="Toggle theme"
  class="border-2 border-black p-1.5 text-black transition-colors hover:bg-black hover:text-white dark:border-white dark:text-white dark:hover:bg-white dark:hover:text-black"
>
  <!-- Sun — shown in dark mode (click to go light) -->
  <svg
    class="hidden h-3.5 w-3.5 dark:block"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
    ></path>
  </svg>
  <!-- Moon — shown in light mode (click to go dark) -->
  <svg
    class="block h-3.5 w-3.5 dark:hidden"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  import { toggleTheme } from '../scripts/theme'

  function init() {
    const btn = document.getElementById('theme-toggle')
    if (!btn) return
    btn.addEventListener('click', () => {
      if (document.startViewTransition) {
        document.startViewTransition(() => toggleTheme())
      } else {
        toggleTheme()
      }
    })
  }

  // Run on first load and after every <ViewTransitions /> navigation
  init()
  document.addEventListener('astro:page-load', init)
</script>
