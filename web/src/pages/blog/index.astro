---
import Base from '../../layouts/Base.astro'
import PostCard from '../../components/PostCard.astro'
import { api } from '../../lib/api'
import type { PostSummary } from '../../lib/types'

const posts = await api.getPosts('en').then((r) => r.data).catch(() => [] as PostSummary[])

const title = 'Writing | Brendatama Akbar'
const description = 'Writing on software, design, and the web.'
---

<Base title={title} description={description} ogType="website">
  <div class="mb-12">
    <h1 class="mb-4 text-5xl font-black tracking-tighter text-black uppercase sm:text-7xl dark:text-white">
      Writing
    </h1>
    <p class="text-base leading-relaxed text-black/60 dark:text-white/60">
      {description}
    </p>
  </div>

  <!-- Tag filter — populated and wired by client script below -->
  <div id="tag-bar" class="mb-6 flex flex-wrap gap-2" aria-label="Filter by tag">
    <button
      class="tag-btn active font-mono text-[10px] font-bold tracking-widest uppercase border-2 border-black px-3 py-1 transition-colors"
      data-tag=""
    >
      All
    </button>
  </div>

  <div id="post-list" class="flex flex-col gap-4">
    {posts.map((post) => (
      <div class="post-item" data-tags={post.tags.map((t) => t.slug).join(',')}>
        <PostCard post={post} />
      </div>
    ))}
    {posts.length === 0 && (
      <p class="py-8 font-mono text-[11px] tracking-widest text-black/40 uppercase dark:text-white/40">
        No posts yet.
      </p>
    )}
  </div>
</Base>

<style>
  .tag-btn {
    background: transparent;
    color: inherit;
    cursor: pointer;
  }
  .tag-btn.active {
    background: #000;
    color: #fff;
  }
  :global(.dark) .tag-btn.active {
    background: #fff;
    color: #000;
  }
</style>

<script define:vars={{ initialPosts: posts }}>
  function initBlogFilter() {
    const tagBar = document.getElementById('tag-bar')
    const postList = document.getElementById('post-list')
    if (!tagBar || !postList) return

    // Build tag map from rendered posts
    const items = Array.from(postList.querySelectorAll('.post-item'))
    const tagNames = {}
    const seen = new Set()

    initialPosts.forEach((post) => {
      post.tags.forEach((tag) => {
        tagNames[tag.slug] = tag.name
        seen.add(tag.slug)
      })
    })

    // Render tag buttons
    seen.forEach((slug) => {
      const btn = document.createElement('button')
      btn.className = 'tag-btn font-mono text-[10px] font-bold tracking-widest uppercase border-2 border-black px-3 py-1 transition-colors'
      btn.dataset.tag = slug
      btn.textContent = `#${tagNames[slug] ?? slug}`
      tagBar.appendChild(btn)
    })

    let activeTag = ''

    const applyFilter = () => {
      items.forEach((item) => {
        const tags = item.dataset.tags ? item.dataset.tags.split(',') : []
        const show = !activeTag || tags.includes(activeTag)
        item.style.display = show ? '' : 'none'
      })
      tagBar.querySelectorAll('.tag-btn').forEach((btn) => {
        btn.classList.toggle('active', btn.dataset.tag === activeTag)
      })
    }

    tagBar.addEventListener('click', (e) => {
      const btn = e.target.closest('.tag-btn')
      if (!btn) return
      activeTag = btn.dataset.tag === activeTag ? '' : btn.dataset.tag
      applyFilter()
    })
  }

  initBlogFilter()
  document.addEventListener('astro:page-load', initBlogFilter)
</script>
