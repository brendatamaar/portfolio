{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["bun-types"],
    "rootDir": "..",
    "composite": false,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@portfolio/shared/*": ["../shared/*"]
    }
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "../shared/**/*"],
  "exclude": ["node_modules", "dist"]
}
