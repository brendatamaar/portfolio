{
  "name": "portofolio-brenda",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web,admin -c yellow,cyan,magenta \"npm run dev --prefix server\" \"npm run dev --prefix web\" \"npm run dev --prefix admin\"",
    "build:web": "npm run build --prefix web",
    "build:admin": "npm run build --prefix admin",
    "lint": "eslint .",
    "format": "prettier --write \"shared/**/*.ts\" \"server/src/**/*.ts\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "concurrently": "^9.0.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "typescript": "^5"
  }
}
