{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "paths": {
      "@portfolio/shared/*": ["./shared/*"]
    }
  },
  "include": ["shared/**/*.ts"],
  "exclude": ["node_modules", "shared/**/*.test.ts"]
}
